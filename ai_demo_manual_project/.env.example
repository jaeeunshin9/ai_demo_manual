# Gemini API 키 (https://aistudio.google.com/apikey 에서 발급)
GEMINI_API_KEY=your_gemini_api_key_here

# 사용할 Gemini 모델명
GEMINI_MODEL=gemini-2.0-flash

# 서버 바인딩 주소 (0.0.0.0 = 외부 접속 허용, 127.0.0.1 = 로컬만)
HOST=0.0.0.0

# GitHub Personal Access Token (https://github.com/settings/tokens 에서 발급)
# repo 읽기 권한(read:contents)만 있으면 됩니다
GITHUB_TOKEN=your_github_token_here
